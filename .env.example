# =============================================================
#  إعدادات مصدر البيانات — شاهي الجبل
#  انسخ هذا الملف إلى .env.local وعدّل القيم.
# =============================================================

# مصدر البيانات: mock (افتراضي) أو accounting للربط الحقيقي
DATA_SOURCE=mock

# --- بيانات الاتصال بالنظام المحاسبي (تُستخدم فقط عند DATA_SOURCE=accounting) ---
# عنوان الـ API الأساسي، مثال لدفترة: https://<your-subdomain>.daftra.com
ACCOUNTING_API_URL=

# مفتاح الـ API السرّي (يبقى على الخادم فقط — لا يُكشف للمتصفح)
ACCOUNTING_API_KEY=

# معرّف الفرع/الموقع (اختياري)
ACCOUNTING_BRANCH_ID=
